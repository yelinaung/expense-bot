{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "minimumReleaseAge": "3 days",
  "packageRules": [
    {
      "matchManagers": [
        "gomod"
      ],
      "postUpdateOptions": [
        "gomodTidy"
      ]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^runner\\/Dockerfile$/"
      ],
      "matchStrings": [
        "(?m)^ARG\\s+NODE20_VERSION=(?<currentValue>[0-9A-Za-z._-]+)\\s*$"
      ],
      "datasourceTemplate": "node-version",
      "depNameTemplate": "node",
      "allowedVersions": "20.x",
      "versioningTemplate": "node"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^runner\\/Dockerfile$/"
      ],
      "matchStrings": [
        "(?m)^ARG\\s+NODE24_VERSION=(?<currentValue>[0-9A-Za-z._-]+)\\s*$"
      ],
      "datasourceTemplate": "node-version",
      "depNameTemplate": "node24",
      "packageNameTemplate": "node",
      "allowedVersions": "24.x",
      "versioningTemplate": "node"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^runner\\/Dockerfile$/"
      ],
      "matchStrings": [
        "(?m)^ARG\\s+GO_VERSION=(?<currentValue>[0-9A-Za-z._-]+)\\s*$"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "golang/go",
      "extractVersionTemplate": "^go(?<version>.*)$",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^runner\\/Dockerfile$/"
      ],
      "matchStrings": [
        "(?m)^ARG\\s+GOLANGCI_LINT_VERSION=(?<currentValue>[0-9A-Za-z._-]+)\\s*$"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "golangci/golangci-lint",
      "extractVersionTemplate": "^v?(?<version>.*)$",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^runner\\/Dockerfile$/"
      ],
      "matchStrings": [
        "(?m)^ARG\\s+GORELEASER_VERSION=(?<currentValue>[0-9A-Za-z._-]+)\\s*$"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "goreleaser/goreleaser",
      "extractVersionTemplate": "^v?(?<version>.*)$",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^runner\\/Dockerfile$/"
      ],
      "matchStrings": [
        "(?m)^ARG\\s+GITLEAKS_VERSION=(?<currentValue>[0-9A-Za-z._-]+)\\s*$"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "gitleaks/gitleaks",
      "extractVersionTemplate": "^v?(?<version>.*)$",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github\\/workflows\\/.*\\.yml$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[^\\s]+)\\s+depName=(?<depName>[^\\s]+)\\n.*?(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)"
      ],
      "versioningTemplate": "semver"
    }
  ]
}
